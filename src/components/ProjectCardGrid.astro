---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<button 
  class="project-card-grid group flex flex-col w-full text-left focus:outline-none"
  data-project={JSON.stringify(project)}
>
  <div class="archive-border bg-white w-full aspect-square relative overflow-hidden p-2 bg-[var(--color-paper)]">
    <!-- Number Badge -->
    <div class="absolute top-4 left-4 z-10 bg-white rounded-full w-6 h-6 flex items-center justify-center text-[10px] archive-border shadow-sm">
      {project.number}
    </div>
    
    <div class="w-full h-full overflow-hidden bg-black/5 relative group-hover:bg-transparent transition-colors">
      <img 
        src={project.image.src} 
        alt={project.image.alt} 
        loading="lazy"
        decoding="async"
        class="w-full h-full object-cover filter grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700 ease-out" 
      />
    </div>
  </div>
  
  <div class="archive-border archive-border-t-0 p-3 bg-[var(--color-paper)] flex flex-col gap-2 relative z-10 group-hover:bg-white transition-colors duration-300">
    <div class="flex justify-between items-center text-[10px] text-black/60 uppercase">
      <span>{project.category}</span>
      <span>{project.year}</span>
    </div>
    <h3 class="font-bold uppercase tracking-tight text-lg leading-none">{project.title}</h3>
  </div>
</button>
