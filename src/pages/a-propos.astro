---
import Layout from '../layouts/Layout.astro';
import { about } from '../data/about';
---

<Layout title="Claire MILLETTI | À Propos">
  <div class="w-full pt-8 pb-32">
    
    <div class="border-b border-black/20 pb-4 mb-12">
      <h1 class="text-4xl md:text-6xl font-bold uppercase tracking-tighter">{about.title}</h1>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-12 items-start">
      
      <div class="md:col-span-4 relative flex justify-center mt-6">
        <div class="relative w-full h-[400px] sm:h-[450px] flex justify-center mt-8">
          {about.photos.map((photo, i) => {
            const positions = [
              "top-0 left-0 sm:left-4 w-40 rotate-[-6deg] aspect-[3/4] z-10",
              "top-20 right-0 sm:right-4 w-44 rotate-[3deg] aspect-square z-20",
              "top-40 left-8 sm:left-12 w-48 rotate-[-2deg] aspect-[4/3] z-30"
            ];
            const tapeRotations = ["-3deg", "4deg", "-1deg"];
            
            return (
              <div class={`collage-photo absolute ${positions[i]} bg-white p-2 pb-8 shadow-md transform hover:rotate-0 hover:z-50 hover:scale-110 transition-transform duration-300 archive-border cursor-pointer`}>
                <div class="absolute -top-3 left-1/2 -translate-x-1/2 w-16 h-6 bg-red-600 shadow-sm z-10 transform rotate-[{tapeRotations[i]}] opacity-90 flex items-center justify-center overflow-hidden">
                  <div class="w-full h-px bg-black/10 absolute top-1/2 transform -rotate-6"></div>
                </div>
                <img src={photo.src} alt={photo.alt} loading="lazy" decoding="async" class="w-full h-auto object-cover filter grayscale sepia-[0.1] hover:grayscale-0 hover:sepia-0 transition-all duration-500" />
                <div class="absolute bottom-2 left-0 w-full text-center text-[8px] text-black/50">
                  {photo.fig}
                </div>
              </div>
            );
          })}
        </div>
      </div>

      <div class="md:col-span-8 flex flex-col gap-8 md:gap-16">
        
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 text-sm leading-relaxed text-black/80">
          <div>
            <p class="mb-4">
              {about.bio[0]}
            </p>
            <p>
              {about.bio[1]}
            </p>
          </div>
          <div>
            <p class="mb-4">
              {about.bio[2]}
            </p>
            <p>
              {about.bio[3]}
            </p>
          </div>
        </div>

        <div>
          <div class="border-b border-black/20 pb-2 mb-6">
            <h2 class="text-2xl font-bold uppercase tracking-tighter">{about.expertiseTitle}</h2>
          </div>
          
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 md:gap-8">
            {about.expertises.map((exp) => (
              <div class="flex flex-col gap-2">
                <div class="text-[10px] text-black/50 border-b border-black/10 pb-1">{exp.number}. {exp.category}</div>
                <h3 class="font-bold">{exp.title}</h3>
                <p class="text-xs text-black/70 mt-2">
                  {exp.description}
                </p>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </div>
</Layout>
