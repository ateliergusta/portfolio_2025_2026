---
import Layout from '../layouts/Layout.astro';
import ProjectCardStacked from '../components/ProjectCardStacked.astro';
import ProjectCardGrid from '../components/ProjectCardGrid.astro';
import ProjectModal from '../components/ProjectModal.astro';
import { projects } from '../data/projects';
---

<Layout title="Claire MILLETTI | Archive @2025">
  <!-- Stacked View Container -->
  <div id="view-stacked-container" class="w-full flex flex-col pt-8 pb-32">
    {projects.map((project, index) => (
      <ProjectCardStacked project={project} index={index} />
    ))}
  </div>

  <!-- Grid View Container -->
  <div id="view-grid-container" class="hidden w-full pt-8 pb-32 transition-opacity duration-500">
    <div class="flex justify-between items-end border-b border-black/20 pb-4 mb-8">
      <div>
        <div class="text-[10px] text-black/50 mb-1">VUE GRILLE - CLIQUEZ POUR OUVRIR</div>
        <h1 class="text-3xl font-bold tracking-tighter">INDEX DES PROJETS</h1>
      </div>
      <div class="text-[10px] text-black/50">{projects.length} fiches</div>
    </div>
    
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-6">
      {projects.map((project) => (
        <ProjectCardGrid project={project} />
      ))}
    </div>
  </div>

  <ProjectModal />
</Layout>

<script>
  // UI Logic for toggling views and opening modals
  document.addEventListener('DOMContentLoaded', () => {
    
    // --- View Toggle Logic ---
    const btnStacked = document.getElementById('view-stacked');
    const btnGrid = document.getElementById('view-grid');
    const containerStacked = document.getElementById('view-stacked-container');
    const containerGrid = document.getElementById('view-grid-container');
    
    // Default styles for active/inactive buttons
    const activeClasses = ['bg-white', 'text-black'];
    const inactiveClasses = ['text-white', 'hover:bg-white/20'];
    
    function setView(view: 'stacked' | 'grid') {
      if (!btnStacked || !btnGrid || !containerStacked || !containerGrid) return;
      
      if (view === 'stacked') {
        // Show stacked, hide grid
        containerStacked.classList.remove('hidden');
        containerGrid.classList.add('hidden');
        
        // Update buttons
        btnStacked.classList.add(...activeClasses);
        btnStacked.classList.remove(...inactiveClasses);
        btnGrid.classList.add(...inactiveClasses);
        btnGrid.classList.remove(...activeClasses);
        
        // Scroll to top
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } else {
        // Show grid, hide stacked
        containerGrid.classList.remove('hidden');
        containerStacked.classList.add('hidden');
        
        // Update buttons
        btnGrid.classList.add(...activeClasses);
        btnGrid.classList.remove(...inactiveClasses);
        btnStacked.classList.add(...inactiveClasses);
        btnStacked.classList.remove(...activeClasses);
        
        // Scroll to top
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    }

    btnStacked?.addEventListener('click', () => setView('stacked'));
    btnGrid?.addEventListener('click', () => setView('grid'));
    
    // --- Modal Logic ---
    const modal = document.getElementById('project-modal');
    const modalBackdrop = document.getElementById('modal-backdrop');
    const modalContent = document.getElementById('modal-content');
    const btnClose = document.getElementById('close-modal');
    
    // Modal Elements to populate
    const elNum = document.getElementById('modal-number');
    const elHeaderYear = document.getElementById('modal-header-year');
    const elCategory = document.getElementById('modal-category');
    const elImage = document.getElementById('modal-image') as HTMLImageElement;
    const elVideo = document.getElementById('modal-video') as HTMLVideoElement;
    const elTitle = document.getElementById('modal-title');
    const elDesc = document.getElementById('modal-desc');
    const elClient = document.getElementById('modal-client');
    const elYear = document.getElementById('modal-year');
    const elRole = document.getElementById('modal-role');
    const elLocation = document.getElementById('modal-location');
    const elTags = document.getElementById('modal-tags');
    
    function openModal(projectData: any) {
      if (!modal || !modalBackdrop || !modalContent) return;
      
      // Populate Data
      if (elNum) elNum.textContent = projectData.number;
      if (elHeaderYear) elHeaderYear.textContent = projectData.year;
      if (elCategory) elCategory.textContent = projectData.category;
      if (elImage && elVideo) {
        const hasVideo = projectData.image.videoSrc;
        if (hasVideo) {
          elImage.classList.add('hidden');
          elVideo.classList.remove('hidden');
          elVideo.src = projectData.image.videoSrc;
          elVideo.play();
        } else {
          elVideo.classList.add('hidden');
          elVideo.pause();
          elVideo.src = '';
          elImage.classList.remove('hidden');
          elImage.src = projectData.image.src;
          const isPortrait = projectData.image.portrait;
          elImage.className = isPortrait ? 'max-h-full w-auto max-w-sm object-cover' : 'w-full h-full object-cover object-top';
        }
      }
      if (elTitle) elTitle.textContent = projectData.title;
      if (elDesc) elDesc.textContent = projectData.longDesc;
      if (elClient) elClient.textContent = projectData.client;
      if (elYear) elYear.textContent = projectData.year;
      if (elRole) elRole.textContent = projectData.role;
      if (elLocation) elLocation.textContent = projectData.location;
      
      if (elTags) {
        elTags.innerHTML = '';
        projectData.tags.forEach((tag: string) => {
          const span = document.createElement('span');
          span.className = 'px-2 py-1 archive-border text-[10px] uppercase';
          span.textContent = tag;
          elTags.appendChild(span);
        });
      }
      
       const elGallery = document.getElementById('modal-gallery');
      if (elGallery) {
        elGallery.innerHTML = '';
        if (projectData.gallery && projectData.gallery.length > 0) {
           projectData.gallery.forEach((item: { src: string; alt: string; fill?: boolean }) => {
            const imgContainer = document.createElement('div');
            
            imgContainer.className = `w-full bg-black/5 archive-border flex items-center justify-center ${item.fill ? 'min-h-[400px]' : ''}`;
            
            const img = document.createElement('img');
            img.src = item.src;
            img.alt = item.alt;
            img.className = item.fill
              ? 'w-full h-full object-cover block'
              : 'w-full h-auto object-contain block';
            img.loading = 'lazy';
            
            imgContainer.appendChild(img);
            elGallery.appendChild(imgContainer);
          });
        }
      }
      
      // Reset scroll position of modal content
      const modalScrollContainer = document.querySelector('.lenis-modal-scroll');
      if (modalScrollContainer) {
        modalScrollContainer.scrollTop = 0;
      }
      
      // Show Modal
      modal.classList.remove('hidden');
      modal.classList.add('flex');
      
      // Force reflow for transitions
      void modal.offsetWidth;
      
      // Animate In
      modalBackdrop.classList.replace('opacity-0', 'opacity-100');
      modalContent.classList.replace('opacity-0', 'opacity-100');
      modalContent.classList.replace('scale-95', 'scale-100');
      
      // Prevent body scroll (Lenis will ignore the scroll inside the modal thanks to data-lenis-prevent)
      document.body.style.overflow = 'hidden';
    }
    
    function closeModal() {
      if (!modal || !modalBackdrop || !modalContent) return;
      
      // Animate Out
      modalBackdrop.classList.replace('opacity-100', 'opacity-0');
      modalContent.classList.replace('opacity-100', 'opacity-0');
      modalContent.classList.replace('scale-100', 'scale-95');
      
      // Wait for transition to end before hiding
      setTimeout(() => {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        document.body.style.overflow = '';
      }, 500);
    }
    
    // Add click listeners to all project cards (grid and stacked)
    const projectCards = document.querySelectorAll('.project-card-grid, .project-card-stacked');
    projectCards.forEach(card => {
      card.addEventListener('click', (e) => {
        const dataStr = card.getAttribute('data-project');
        if (dataStr) {
          try {
            const data = JSON.parse(dataStr);
            openModal(data);
          } catch(err) {
            console.error("Error parsing project data", err);
          }
        }
      });
    });
    
    btnClose?.addEventListener('click', closeModal);
    modalBackdrop?.addEventListener('click', closeModal);
    
    // Escape key to close modal
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal?.classList.contains('hidden')) {
        closeModal();
      }
    });
  });
</script>
